# --- BrainBack.AI / BankBot .gitignore ---

# Data & Models (Crucial: Keep large binary models out of Git)
data/
*.onnx
*.bin
*.tar.bz2
*.tar.gz

# Python & Environment
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Audio Cache & Logs (Temporary session data)
tts_cache/
logs/
*.wav
*.webm
*.mp3

# IDEs & System Files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Environmental variables
.env
